{
  "name": "vibe-db",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "env-cmd -f .env.dev next dev",
    "build": "env-cmd -f .env.prod next build",
    "start": "env-cmd -f .env.prod next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:migrate": "env-cmd -f .env.dev prisma migrate dev",
    "db:migrate:prod": "env-cmd -f .env.prod prisma migrate deploy"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@dbml/core": "^7.0.0-alpha.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "9.0.0",
    "@mantine/hooks": "9.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "lucide-react": "^1.7.0",
    "mantine-datatable": "^8.3.13",
    "next": "^16.2.1-canary.16",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-split-pane": "^3.2.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "env-cmd": "^11.0.0",
    "postcss": "^8.4.38",
    "postcss-preset-mantine": "^1.15.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.6.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2"
  }
}
